{
  "info": {
    "name": "WorkHub Phase 2 — Week 12 (SaaS Hardening)",
    "description": "Demonstrates tenant isolation, RBAC, async messaging, and observability",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string"
    },
    {
      "key": "correlationId",
      "value": "trace-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "Health - Overall Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health status is UP', function () { pm.expect(pm.response.json().status).to.equal('UP'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Health - Liveness (no auth required)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/health/liveness",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health", "liveness"]
            }
          }
        },
        {
          "name": "Health - Readiness (no auth required)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/health/readiness",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health", "readiness"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Authentication & Authorization",
      "item": [
        {
          "name": "Login - Tenant Admin (ACME)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@acme.com\", \"password\": \"admin123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login successful', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Metrics - Requires TENANT_ADMIN (should succeed)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/actuator/prometheus",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "prometheus"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Metrics endpoint requires auth, should be 200 with admin', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Async Report Generation Flow",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Phase 2 Demo Project\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Project created', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('projectId', data.projectId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Trigger Async Report (202 Accepted)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/generate-report",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "generate-report"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Report job accepted (202)', function () { pm.response.to.have.status(202); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('jobId', data.jobId);",
                  "var correlationId = pm.response.headers.get('X-Correlation-ID');",
                  "console.log('Correlation ID: ' + correlationId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Poll Report Status (immediate - should be PENDING)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/report-status",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "report-status"]
            }
          }
        },
        {
          "name": "Poll Report Status (after 3s - should be DONE)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/report-status",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "report-status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Report completed', function () { pm.expect(pm.response.json().reportStatus).to.equal('DONE'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Tenant Isolation Verification",
      "item": [
        {
          "name": "Login - Other Tenant (BETA Corp)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@beta.com\", \"password\": \"beta123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login successful', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Attempt to Access ACME Project (should fail 403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Access denied (403)', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Observability Metrics",
      "item": [
        {
          "name": "Login again as ACME",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@acme.com\", \"password\": \"admin123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Prometheus Metrics (grep for workhub metrics)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/actuator/prometheus",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "prometheus"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Metrics available', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.text();",
                  "pm.test('Contains WorkHub metrics', function () { pm.expect(body).to.include('workhub_report'); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
