{
  "info": {
    "name": "Workhub Phase1 Week7",
    "description": "Login + project/task APIs including transactional rollback demo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('token', data.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Projects - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Week7 Main Project\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('projectId', data.projectId);"
            ]
          }
        }
      ]
    },
    {
      "name": "Projects - Get All",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects"
          ]
        }
      }
    },
    {
      "name": "Projects - Get By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{projectId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects",
            "{{projectId}}"
          ]
        }
      }
    },
    {
      "name": "Tasks - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"TODO\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects",
            "{{projectId}}",
            "tasks"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('taskId', data.taskId);"
            ]
          }
        }
      ]
    },
    {
      "name": "Tasks - Update",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"DONE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/{{taskId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks",
            "{{taskId}}"
          ]
        }
      }
    },
    {
      "name": "Rollback Demo - Create Project",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Week7 Rollback Project\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('rollbackProjectId', data.projectId);"
            ]
          }
        }
      ]
    },
    {
      "name": "Rollback Demo - Simulate Failure",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/projects/{{rollbackProjectId}}/tasks?simulateFailure=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects",
            "{{rollbackProjectId}}",
            "tasks"
          ],
          "query": [
            {
              "key": "simulateFailure",
              "value": "true"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 500', function () { pm.response.to.have.status(500); });",
              "pm.test('has simulated error', function () {",
              "  pm.expect(pm.response.json().error).to.eql('Simulated transactional failure');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Rollback Demo - Verify Project",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/projects/{{rollbackProjectId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "projects",
            "{{rollbackProjectId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('tasks list remains empty after rollback', function () {",
              "  pm.expect(pm.response.json().tasks.length).to.eql(0);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "rollbackProjectId",
      "value": ""
    }
  ]
}
